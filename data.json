      "config": {
        "title": "Quantum",
        "libs": ["https://cdn.tailwindcss.com"],
        "css": "body{background-color:#030712;color:#fff;font-family:Inter,system-ui,sans-serif;margin:0;overflow-x:hidden}.glass-nav{background:rgba(255,255,255,0.03);backdrop-filter:blur(10px);border-bottom:1px solid rgba(255,255,255,0.05)}.glow-bg{position:absolute;width:600px;height:600px;background:radial-gradient(circle,rgba(56,189,248,0.15) 0%,rgba(0,0,0,0) 70%);top:-200px;left:50%;transform:translateX(-50%);z-index:-1}.gradient-text{background:linear-gradient(to right,#38bdf8,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent}.card-glass{background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.05);border-radius:1rem;transition:all .3s ease}.card-glass:hover{background:rgba(255,255,255,0.04);border-color:rgba(56,189,248,0.3);transform:translateY(-5px)}",
        "js": "document.getElementById('cta-btn').addEventListener('click',()=>{alert('Quantum Engine Initialized.');});",
        "html": "<div class='min-h-screen relative flex flex-col'><div class='glow-bg'></div><nav class='glass-nav w-full fixed top-0 z-50 flex justify-between items-center px-8 py-4'><div class='text-xl font-bold tracking-widest'>QUANTUM</div><ul class='flex space-x-6 text-sm text-gray-400'><li><a href='#' class='hover:text-white transition'>Features</a></li><li><a href='#' class='hover:text-white transition'>Pricing</a></li><li><a href='#' class='hover:text-white transition'>Docs</a></li></ul></nav><main class='flex-grow flex flex-col items-center justify-center text-center px-4 pt-32 pb-20'><h1 class='text-6xl md:text-7xl font-extrabold tracking-tight mb-6'>Build the <span class='gradient-text'>Future</span></h1><p class='text-gray-400 text-lg max-w-2xl mb-10'>The most advanced architectural framework for next-generation applications. Seamlessly integrated, boundlessly scalable.</p><button id='cta-btn' class='bg-white text-black px-8 py-3 rounded-full font-semibold hover:bg-gray-200 transition shadow-[0_0_20px_rgba(255,255,255,0.3)]'>Start Building</button><div class='grid grid-cols-1 md:grid-cols-3 gap-6 mt-24 max-w-5xl w-full'><div class='card-glass p-8 text-left'><h3 class='text-xl font-semibold mb-3'>Lightning Fast</h3><p class='text-gray-400 text-sm'>Optimized for speed with zero-runtime overhead.</p></div><div class='card-glass p-8 text-left'><h3 class='text-xl font-semibold mb-3'>Secure Core</h3><p class='text-gray-400 text-sm'>Enterprise-grade security built directly into the foundation.</p></div><div class='card-glass p-8 text-left'><h3 class='text-xl font-semibold mb-3'>Global Edge</h3><p class='text-gray-400 text-sm'>Deploy worldwide in milliseconds with edge networks.</p></div></div></main></div>"
      }
    },
    {
      "id": "app_02",
      "name": "Neo Dashboard",
      "thumb": "https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400",
      "config": {
        "title": "Dashboard",
        "libs": [],
        "css": "*{box-sizing:border-box}body{margin:0;font-family:system-ui,-apple-system,sans-serif;background-color:#0f111a;color:#e2e8f0}.dashboard{display:flex;height:100vh;overflow:hidden}.sidebar{width:260px;background:#161925;border-right:1px solid #232738;padding:24px;display:flex;flex-direction:column}.brand{font-size:1.25rem;font-weight:700;color:#fff;margin-bottom:40px;display:flex;align-items:center;gap:10px}.nav-item{padding:12px 16px;color:#94a3b8;text-decoration:none;border-radius:8px;margin-bottom:8px;transition:all .2s;font-weight:500;display:block}.nav-item.active,.nav-item:hover{background:#232738;color:#60a5fa}.main-content{flex:1;padding:32px;overflow-y:auto}.header{display:flex;justify-content:space-between;align-items:center;margin-bottom:32px}.title{font-size:1.5rem;font-weight:600;margin:0;color:#fff}.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:24px;margin-bottom:32px}.stat-card{background:#161925;border:1px solid #232738;border-radius:12px;padding:24px;box-shadow:0 4px 6px -1px rgba(0,0,0,0.1)}.stat-title{font-size:0.875rem;color:#94a3b8;margin:0 0 12px 0;text-transform:uppercase;letter-spacing:0.05em}.stat-value{font-size:2rem;font-weight:700;color:#fff;margin:0}.recent-table{width:100%;background:#161925;border-radius:12px;border:1px solid #232738;border-collapse:collapse;overflow:hidden}.recent-table th,.recent-table td{padding:16px 24px;text-align:left;border-bottom:1px solid #232738}.recent-table th{font-size:0.75rem;text-transform:uppercase;color:#94a3b8;background:#1a1d2d}.status{padding:4px 10px;border-radius:999px;font-size:0.75rem;font-weight:600}.status.success{background:rgba(52,211,153,0.1);color:#34d399}",
        "js": "function animateValue(id,start,end,duration){let obj=document.getElementById(id);let startTimestamp=null;const step=(timestamp)=>{if(!startTimestamp)startTimestamp=timestamp;const progress=Math.min((timestamp-startTimestamp)/duration,1);obj.innerHTML=Math.floor(progress*(end-start)+start).toLocaleString();if(progress<1){window.requestAnimationFrame(step)}};window.requestAnimationFrame(step)}animateValue('stat1',0,24593,1500);animateValue('stat2',0,843,1000);",
        "html": "<div class='dashboard'><aside class='sidebar'><div class='brand'><div style='width:12px;height:12px;background:#60a5fa;border-radius:50%;'></div> NEO ADMIN</div><nav><a href='#' class='nav-item active'>Overview</a><a href='#' class='nav-item'>Analytics</a><a href='#' class='nav-item'>Customers</a><a href='#' class='nav-item'>Settings</a></nav></aside><main class='main-content'><header class='header'><h1 class='title'>System Overview</h1><div style='background:#232738;padding:8px 16px;border-radius:20px;font-size:0.875rem;'>Admin User</div></header><div class='stats-grid'><div class='stat-card'><h3 class='stat-title'>Total Revenue</h3><p class='stat-value'>$<span id='stat1'>0</span></p></div><div class='stat-card'><h3 class='stat-title'>Active Sessions</h3><p class='stat-value' id='stat2'>0</p></div><div class='stat-card'><h3 class='stat-title'>System Health</h3><p class='stat-value' style='color:#34d399;'>99.9%</p></div></div><table class='recent-table'><thead><tr><th>Transaction ID</th><th>User</th><th>Amount</th><th>Status</th></tr></thead><tbody><tr><td>#TRX-00192</td><td>Alex Mason</td><td>$1,200.00</td><td><span class='status success'>Completed</span></td></tr><tr><td>#TRX-00191</td><td>Sarah Chen</td><td>$850.50</td><td><span class='status success'>Completed</span></td></tr></tbody></table></main></div>"
      }
    },
    {
      "id": "app_03",
      "name": "Onyx Store",
      "thumb": "https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=400",
      "config": {
        "title": "Onyx",
        "libs": [],
        "css": "*{box-sizing:border-box}body{margin:0;font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;background:#fff;color:#000}.container{max-width:1440px;margin:0 auto;padding:0 40px}.nav{display:flex;justify-content:space-between;align-items:center;padding:32px 0;border-bottom:1px solid #eaeaea}.logo{font-size:24px;font-weight:900;letter-spacing:-1px;text-transform:uppercase}.cart-btn{background:none;border:none;font-size:16px;font-weight:500;cursor:pointer}.hero{height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;background:#f8f8f8;margin-bottom:60px}.hero h1{font-size:5vw;font-weight:800;letter-spacing:-2px;margin:0;line-height:1}.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:40px;margin-bottom:100px}.product{position:relative;group}.img-box{background:#f0f0f0;aspect-ratio:3/4;width:100%;object-fit:cover;margin-bottom:16px;transition:transform .3s ease}.product:hover .img-box{transform:scale(0.98)}.details{display:flex;justify-content:space-between;align-items:flex-start}.name{font-size:16px;font-weight:600;margin:0 0 8px 0}.price{font-size:16px;color:#666;margin:0}.add-btn{width:100%;padding:16px;background:#000;color:#fff;border:none;font-size:14px;font-weight:600;cursor:pointer;margin-top:16px;opacity:0;transform:translateY(10px);transition:all .3s ease}.product:hover .add-btn{opacity:1;transform:translateY(0)}.add-btn:active{background:#333}.toast{position:fixed;bottom:30px;right:30px;background:#000;color:#fff;padding:16px 24px;border-radius:4px;font-weight:500;transform:translateY(100px);opacity:0;transition:all .3s cubic-bezier(0.68,-0.55,0.265,1.55);z-index:100}.toast.show{transform:translateY(0);opacity:1}",
        "js": "let count=0;function addCart(item){count++;document.getElementById('cart-count').innerText=count;showToast(item+' added to cart');}function showToast(msg){const t=document.getElementById('toast');t.innerText=msg;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),3000);}",
        "html": "<div class='container'><nav class='nav'><div class='logo'>Onyx.</div><button class='cart-btn'>Cart (<span id='cart-count'>0</span>)</button></nav><header class='hero'><h1>ESSENTIALS<br>COLLECTION</h1></header><div class='grid'><div class='product'><div class='img-box' style='background:url(https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=600) center/cover'></div><div class='details'><div><h3 class='name'>Classic Timepiece</h3><p class='price'>$245.00</p></div></div><button class='add-btn' onclick='addCart(\"Classic Timepiece\")'>Add to Cart</button></div><div class='product'><div class='img-box' style='background:url(https://images.unsplash.com/photo-1627384113743-6bd5a479fffd?w=600) center/cover'></div><div class='details'><div><h3 class='name'>Leather Carry</h3><p class='price'>$189.00</p></div></div><button class='add-btn' onclick='addCart(\"Leather Carry\")'>Add to Cart</button></div><div class='product'><div class='img-box' style='background:url(https://images.unsplash.com/photo-1584916201218-f4242ceb4809?w=600) center/cover'></div><div class='details'><div><h3 class='name'>Minimal Wallet</h3><p class='price'>$65.00</p></div></div><button class='add-btn' onclick='addCart(\"Minimal Wallet\")'>Add to Cart</button></div></div><div id='toast' class='toast'></div></div>"
      }
    }
  ]
}